{
  "name": "app-admin-test",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run api:stop && concurrently -k -n FRONT,API -c blue,green \"npm run start:host\" \"npm run api\"",
    "start:front": "ng serve",
    "start:host": "ng serve --host 0.0.0.0 --port 4200",
    "api": "npm --prefix api run dev",
    "api:start": "npm --prefix api run start",
    "api:db:init": "npm --prefix api run db:init",
    "api:stop": "bash -lc 'fuser -k 3000/tcp 2>/dev/null || true'",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --coverage"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "ng-zorro-antd": "^21.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "@vitest/coverage-v8": "^4.0.8",
    "vitest": "^4.0.8"
  }
}
